local godConn = nil
local function iniciarGod(on)
    if godConn then godConn:Disconnect(); godConn = nil end
    if not on then
        local c = getChar()
        if c then
            for _,p in pairs(c:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = true; p.Transparency = 0 end
            end
        end
        local hum = getHum(); if hum then hum.PlatformStand = false end
        setStat("God Mode OFF", C.verm); return
    end
    godConn = RunService.Heartbeat:Connect(function()
        local hrp = getHRP(); local hum = getHum()
        if not hrp or not hum then return end
        hum.Health = hum.MaxHealth
        for _,o in pairs(workspace:GetDescendants()) do
            local n = o.Name:lower()
            if n:find("tsunami") or n:find("wave") or n:find("flood") or n:find("kill") then
                if o:IsA("BasePart") then pcall(function() o.CanCollide = false end) end
            end
        end
        if hrp.Position.Y < -10 then
            hrp.CFrame = CFrame.new(hrp.Position.X, 8, hrp.Position.Z)
        end
    end)
    setStat("God Mode ON - Invulneravel!", C.verde)
end

