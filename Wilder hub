local function ghostColetar(kw, nome, estadoNome)
    spawn(function()
        while estados[estadoNome] do
            local hrp = getHRP()
            if hrp then
                local found = {}
                for _,o in pairs(workspace:GetDescendants()) do
                    if o.Name:lower():find(kw) then
                        local pos = getPos(o)
                        if pos then found[#found+1] = {o=o,p=pos} end
                    end
                end
                if #found > 0 then
                    setStat("Encontrado: "..nome.." - Coletando...", C.amar)
                    for _,item in pairs(found) do
                        if not estados[estadoNome] then break end
                        local hrp2 = getHRP(); if not hrp2 then break end
                        hrp2.CFrame = CFrame.new(item.p+Vector3.new(0,3,0))
                        task.wait(0.15); ativar(item.o)
                    end
                    local base = buscar({"base","plot","homebase","spawn"})
                    local bpos = getPos(base)
                    local hrp3 = getHRP()
                    if hrp3 and bpos then hrp3.CFrame = CFrame.new(bpos+Vector3.new(0,4,0)) end
                    setStat(nome.." coletado! Voltei pra base.", C.verde)
                else
                    setStat("Procurando "..nome.."...", C.textoSub)
                end
            end
            task.wait(3)
        end
    end)
end

