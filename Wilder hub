local function getChar() return LP.Character end
local function getHRP()
    local c = getChar(); return c and c:FindFirstChild("HumanoidRootPart")
end
local function getHum()
    local c = getChar(); return c and c:FindFirstChildOfClass("Humanoid")
end
local function getPos(o)
    if not o then return nil end
    if o:IsA("Model") and o.PrimaryPart then return o.PrimaryPart.Position
    elseif o:IsA("BasePart") then return o.Position end
end
local function tpPos(pos)
    local hrp = getHRP()
    if hrp and pos then hrp.CFrame = CFrame.new(pos + Vector3.new(0,4,0)) end
end
local function buscar(kws)
    for _,o in pairs(workspace:GetDescendants()) do
        local n = o.Name:lower()
        for _,k in pairs(kws) do if n:find(k) then return o end end
    end
end
local function ativar(o)
    if not o then return end
    pcall(function()
        local pp = o:FindFirstChildOfClass("ProximityPrompt")
            or (o.Parent and o.Parent:FindFirstChildOfClass("ProximityPrompt"))
        if pp then fireproximityprompt(pp) end
    end)
    pcall(function()
        if o:IsA("BasePart") then
            local cd = o:FindFirstChildOfClass("ClickDetector")
            if cd then fireclickdetector(cd) end
        end
    end)
end
local function irZona(kws)
    local o = buscar(kws); local p = getPos(o); if p then tpPos(p) end
end
local loops = {}
local function stopLoop(n)
    if loops[n] then loops[n]:Disconnect(); loops[n] = nil end
end
