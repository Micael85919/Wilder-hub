-- Mapeia botoes sidebar para destacar selecionado
local sideButtons = {}

local function mostrarPagina(nome)
    -- Limpa conteudo atual
    for _, c in pairs(ContentScroll:GetChildren()) do
        if c:IsA("GuiObject") and c ~= ContentList then c:Destroy() end
    end
    -- Destaca botao sidebar
    for n, btn in pairs(sideButtons) do
        if n == nome then
            btn.BackgroundColor3 = C.selecionado
            local str = btn:FindFirstChildOfClass("UIStroke")
            if str then str.Transparency = 0 end
        else
            btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
            btn.BackgroundTransparency = 1
            local str = btn:FindFirstChildOfClass("UIStroke")
            if str then str.Transparency = 1 end
        end
    end
    currentPage = nome
    -- Renderiza itens da pagina
    if pages[nome] then
        for _, fn in pairs(pages[nome]) do
            fn()
        end
    end
end

