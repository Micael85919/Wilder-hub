local function addSideBtn(nome, icone)
    local btn = Instance.new("TextButton", SideScroll)
    btn.Size = UDim2.new(1,0,0,46)
    btn.BackgroundColor3 = C.sidebar
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.BorderSizePixel = 0
    btn.ZIndex = 13

    -- Borda esquerda colorida (indicador selecionado)
    local indicator = Instance.new("Frame", btn)
    indicator.Size = UDim2.new(0,3,0.6,0)
    indicator.Position = UDim2.new(0,0,0.2,0)
    indicator.BackgroundColor3 = C.dest
    indicator.BorderSizePixel = 0
    indicator.Visible = false
    indicator.ZIndex = 14
    corner(indicator, 2)

    local icoL = Instance.new("TextLabel", btn)
    icoL.Size = UDim2.new(1,0,0,20)
    icoL.Position = UDim2.new(0,0,0,6)
    icoL.BackgroundTransparency = 1
    icoL.Text = icone
    icoL.TextColor3 = C.texto
    icoL.TextSize = 14
    icoL.Font = Enum.Font.GothamBold
    icoL.ZIndex = 14

    local nameL = Instance.new("TextLabel", btn)
    nameL.Size = UDim2.new(1,-4,0,16)
    nameL.Position = UDim2.new(0,2,0,26)
    nameL.BackgroundTransparency = 1
    nameL.Text = nome
    nameL.TextColor3 = C.textoSub
    nameL.TextSize = 9
    nameL.Font = Enum.Font.Gotham
    nameL.TextWrapped = true
    nameL.ZIndex = 14

    -- Linha separadora
    local lineD = Instance.new("Frame", btn)
    lineD.Size = UDim2.new(0.8,0,0,1)
    lineD.Position = UDim2.new(0.1,0,1,-1)
    lineD.BackgroundColor3 = C.divisor
    lineD.BorderSizePixel = 0
    lineD.ZIndex = 14

    sideButtons[nome] = btn

    btn.MouseButton1Click:Connect(function()
        mostrarPagina(nome)
        indicator.Visible = true
        icoL.TextColor3 = C.branco
        nameL.TextColor3 = C.texto
        -- Esconde indicador dos outros
        for n, b in pairs(sideButtons) do
            if n ~= nome then
                local ind = b:FindFirstChild("Frame")
                if ind then ind.Visible = false end
                local ic = b:FindFirstChildOfClass("TextLabel")
                if ic then ic.TextColor3 = C.texto end
            end
        end
    end)

    return btn
end

