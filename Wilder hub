-- ===================================================
-- VERIFICACAO DA KEY
-- ===================================================
local function verificarKey()
    local k = keyBox.Text:gsub("%s","")
    if k == VALID_KEY then
        keyMsg.Text = "Key correta! Abrindo..."
        keyMsg.TextColor3 = C.verde
        task.wait(0.8)
        TweenService:Create(KeyBg,TweenInfo.new(0.5),{BackgroundTransparency=1}):Play()
        for _,v in pairs(KeyBg:GetDescendants()) do
            if v:IsA("GuiObject") then
                TweenService:Create(v,TweenInfo.new(0.4),{BackgroundTransparency=1}):Play()
                if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
                    TweenService:Create(v,TweenInfo.new(0.4),{TextTransparency=1}):Play()
                end
            end
        end
        task.wait(0.5)
        KeyBg.Visible = false
        FabF.Visible = true
        setStat("Toque em W para abrir o menu!", C.verde)
    else
        keyMsg.Text = "Key incorreta! Pegue no Discord."
        keyMsg.TextColor3 = C.verm
        local orig = KP.Position
        for _ = 1,4 do
            KP.Position = UDim2.new(orig.X.Scale,orig.X.Offset+7,orig.Y.Scale,orig.Y.Offset)
            task.wait(0.05)
            KP.Position = UDim2.new(orig.X.Scale,orig.X.Offset-7,orig.Y.Scale,orig.Y.Offset)
            task.wait(0.05)
        end
        KP.Position = orig
    end
end

confBtn.MouseButton1Click:Connect(verificarKey)
keyBox.FocusLost:Connect(function(enter) if enter then verificarKey() end end)

