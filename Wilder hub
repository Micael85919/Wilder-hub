local function iniciarFly(on)
    pararFly(); if not on then setStat("Fly OFF", C.verm); return end
    local hrp = getHRP(); if not hrp then return end
    local hum = getHum(); if hum then hum.PlatformStand = true end
    local bg = Instance.new("BodyGyro", hrp)
    bg.Name="WHFlyBG"; bg.MaxTorque=Vector3.new(9e9,9e9,9e9); bg.D=100; bg.P=1e5
    local bv = Instance.new("BodyVelocity", hrp)
    bv.Name="WHFlyBV"; bv.MaxForce=Vector3.new(9e9,9e9,9e9); bv.Velocity=Vector3.new()

    local flyUI = Instance.new("Frame", SG)
    flyUI.Name="FlyUI"; flyUI.Size=UDim2.new(0,200,0,108)
    flyUI.Position=UDim2.new(0.5,-100,1,-126)
    flyUI.BackgroundTransparency=1; flyUI.ZIndex=30

    local held = {}
    local btns = {
        {"Subir",  0.37,0,    Vector3.new(0,1,0)},
        {"Descer", 0.37,0.63, Vector3.new(0,-1,0)},
        {"Esq",    0,   0.31, "left"},
        {"Dir",    0.74,0.31, "right"},
        {"Frente", 0.37,0.31, "front"},
    }
    for _,d in pairs(btns) do
        local b = Instance.new("TextButton", flyUI)
        b.Size=UDim2.new(0,56,0,30); b.Position=UDim2.new(d[2],0,d[3],0)
        b.BackgroundColor3=C.roxo; b.Text=d[1]
        b.TextColor3=C.branco; b.TextSize=10
        b.Font=Enum.Font.GothamBold; b.BorderSizePixel=0; b.ZIndex=31
        corner(b, 6)
        b.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
                held[d[1]] = d[4]
            end
        end)
        b.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
                held[d[1]] = nil
            end
        end)
    end

    local stopB = Instance.new("TextButton", flyUI)
    stopB.Size=UDim2.new(1,0,0,20); stopB.Position=UDim2.new(0,0,1,-22)
    stopB.BackgroundColor3=C.verm; stopB.Text="Parar Fly"
    stopB.TextColor3=C.branco; stopB.TextSize=10
    stopB.Font=Enum.Font.GothamBold; stopB.BorderSizePixel=0; stopB.ZIndex=31
    corner(stopB, 5)
    stopB.MouseButton1Click:Connect(function()
        estados["Fly"] = false; pararFly(); setStat("Fly OFF", C.verm)
    end)

    flyConn = RunService.Heartbeat:Connect(function()
        local hrp2 = getHRP(); if not hrp2 then pararFly(); return end
        local bv2 = hrp2:FindFirstChild("WHFlyBV")
        local bg2 = hrp2:FindFirstChild("WHFlyBG")
        if not bv2 or not bg2 then return end
        local cam = workspace.CurrentCamera
        local dir = Vector3.new()
        for k,v in pairs(held) do
            if type(v)=="userdata" then dir=dir+v
            elseif v=="front" then dir=dir+cam.CFrame.LookVector
            elseif v=="left" then dir=dir-cam.CFrame.RightVector
            elseif v=="right" then dir=dir+cam.CFrame.RightVector
            end
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir=dir+cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir=dir-cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir=dir-cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir=dir+cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir=dir+Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir=dir-Vector3.new(0,1,0) end
        bv2.Velocity = dir.Magnitude>0 and dir.Unit*60 or Vector3.new()
        bg2.CFrame = cam.CFrame
    end)
    setStat("Fly ON! Use botoes ou WASD", C.verde)
end

