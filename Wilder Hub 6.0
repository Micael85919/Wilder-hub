local function C(f,r) Instance.new("UICorner",f).CornerRadius=UDim.new(0,r or 6) end
local function G(f,c1,c2) local g=Instance.new("UIGradient",f) g.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,c1),ColorSequenceKeypoint.new(1,c2)}) end
local function getC() return LP.Character end
local function getH() local c=getC() return c and c:FindFirstChild("HumanoidRootPart") end
local function getHm() local c=getC() return c and c:FindFirstChildOfClass("Humanoid") end
local function gPos(o) if not o then return nil end if o:IsA("Model") and o.PrimaryPart then return o.PrimaryPart.Position elseif o:IsA("BasePart") then return o.Position end end
local function tp(pos) local h=getH() if h and pos then h.CFrame=CFrame.new(pos+Vector3.new(0,4,0)) end end
local function find(kws) for _,o in pairs(workspace:GetDescendants()) do local n=o.Name:lower() for _,k in pairs(kws) do if n:find(k) then return o end end end end
local function act(o) if not o then return end pcall(function() local pp=o:FindFirstChildOfClass("ProximityPrompt") or (o.Parent and o.Parent:FindFirstChildOfClass("ProximityPrompt")) if pp then fireproximityprompt(pp) end end) pcall(function() if o:IsA("BasePart") then local cd=o:FindFirstChildOfClass("ClickDetector") if cd then fireclickdetector(cd) end end end) end
local loops={} local function sl(n) if loops[n] then loops[n]:Disconnect() loops[n]=nil end end
