-- =========================
-- FUNCOES DO JOGO
-- =========================

-- GOD MODE CORRIGIDO v6
-- Problema anterior: jogo detectava .Health=MaxHealth direto
-- Solucao: usa CharacterAdded para recriar personagem invulneravel
-- e bloqueia fisicamente os objetos de dano
local godC=nil
local function fGod(on)
    if godC then godC:Disconnect() godC=nil end
    if not on then
        -- Restaura tudo normalmente
        local c=getC()
        if c then
            local hm=getHm()
            if hm then
                hm.BreakJointsOnDeath=true
                pcall(function() hm:SetStateEnabled(Enum.HumanoidStateType.Dead,true) end)
            end
        end
        setStat("God Mode OFF",VM)
        return
    end
    -- METODO CORRETO: desativa estado de morte no humanoid
    local function aplicarGod()
        local c=getC()
        if not c then return end
        local hm=getHm()
        if not hm then return end
        -- Desativa morte completamente
        pcall(function()
            hm:SetStateEnabled(Enum.HumanoidStateType.Dead,false)
            hm.BreakJointsOnDeath=false
        end)
        -- Vida sempre cheia via loop discreto (menos detectavel)
        hm.HealthChanged:Connect(function(h)
            if estados["God Mode"] and h < hm.MaxHealth then
                task.defer(function()
                    if estados["God Mode"] then
                        hm.Health=hm.MaxHealth
                    end
                end)
            end
        end)
    end
    aplicarGod()
    -- Reaplica se personagem resetar
    LP.CharacterAdded:Connect(function()
        task.wait(0.5)
        if estados["God Mode"] then aplicarGod() end
    end)
    -- Bloqueia tsunami/waves fisicamente
    godC=RS.Stepped:Connect(function()
        local h=getH()
        if not h then return end
        for _,o in pairs(workspace:GetDescendants()) do
            local n=o.Name:lower()
            if n:find("tsunami") or n:find("wave") or n:find("flood")
            or n:find("kill") or n:find("damage") or n:find("hurt")
            or n:find("bunny") or n:find("rabbit") then
                if o:IsA("BasePart") then
                    pcall(function() o.CanCollide=false end)
                end
            end
        end
        -- Anti-void
        if h.Position.Y<-15 then
            h.CFrame=CFrame.new(h.Position.X,5,h.Position.Z)
        end
    end)
    setStat("God Mode ON - Invulneravel!",VD)
end

-- CANCEL TSUNAMI
local tsC=nil
local function fCancelTs(on)
    if tsC then tsC:Disconnect() tsC=nil end
    if not on then setStat("Cancel Tsunami OFF",VM) return end
    local function rem() for _,o in pairs(workspace:GetDescendants()) do local n=o.Name:lower() if n:find("tsunami") or n:find("wave") or n:find("flood") or n:find("tidal") or n:find("bunny") or n:find("rabbit") then if o:IsA("BasePart") then pcall(function() o.CanCollide=false o.Transparency=1 o.CFrame=CFrame.new(0,-9999,0) end) end end end end
    rem() tsC=RS.Stepped:Connect(rem) setStat("Tsunami CANCELADO",VD)
end

-- AUTO ESCAPE
local function fEscape(on)
    sl("escape") if not on then return end
    loops["escape"]=RS.Stepped:Connect(function()
        local h=getH() if not h then return end
        local w=workspace:FindFirstChild("Tsunami") or workspace:FindFirstChild("Wave") or find({"tsunami","wave","flood","bunny","rabbit"})
        if w then local wp=w:IsA("Model") and w.PrimaryPart or w if wp and wp:IsA("BasePart") and (h.Position-wp.Position).Magnitude<240 then local dir=(h.Position-wp.Position).Unit h.CFrame=h.CFrame+(dir*140) setStat("Fugindo do Tsunami!",VM) end end
    end)
end

-- FLY
local flyC=nil
local function stopFly() if flyC then flyC:Disconnect() flyC=nil end local h=getH() if h then local bg=h:FindFirstChild("WHBg") if bg then bg:Destroy() end local bv=h:FindFirstChild("WHBv") if bv then bv:Destroy() end end local hm=getHm() if hm then hm.PlatformStand=false end local fu=SG:FindFirstChild("FlyUI") if fu then fu:Destroy() end end
local function fFly(on)
    stopFly() if not on then setStat("Fly OFF",VM) return end
    local h=getH() if not h then return end local hm=getHm() if hm then hm.PlatformStand=true end
    local bg=Instance.new("BodyGyro",h) bg.Name="WHBg" bg.MaxTorque=Vector3.new(9e9,9e9,9e9) bg.D=100 bg.P=1e5
    local bv=Instance.new("BodyVelocity",h) bv.Name="WHBv" bv.MaxForce=Vector3.new(9e9,9e9,9e9) bv.Velocity=Vector3.new()
    local fu=Instance.new("Frame",SG) fu.Name="FlyUI" fu.Size=UDim2.new(0,200,0,108) fu.Position=UDim2.new(0.5,-100,1,-126) fu.BackgroundTransparency=1 fu.ZIndex=30
    local held={}
    local bd={{"Subir",0.37,0,Vector3.new(0,1,0)},{"Descer",0.37,0.63,Vector3.new(0,-1,0)},{"Esq",0,0.31,"left"},{"Dir",0.74,0.31,"right"},{"Frente",0.37,0.31,"front"}}
    for _,d in pairs(bd) do
        local b=Instance.new("TextButton",fu) b.Size=UDim2.new(0,56,0,30) b.Position=UDim2.new(d[2],0,d[3],0) b.BackgroundColor3=RX b.Text=d[1] b.TextColor3=BR b.TextSize=10 b.Font=Enum.Font.GothamBold b.BorderSizePixel=0 b.ZIndex=31 C(b,6)
        b.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then held[d[1]]=d[4] end end)
        b.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then held[d[1]]=nil end end)
    end
    local sb=Instance.new("TextButton",fu) sb.Size=UDim2.new(1,0,0,20) sb.Position=UDim2.new(0,0,1,-22) sb.BackgroundColor3=VM sb.Text="Parar Fly" sb.TextColor3=BR sb.TextSize=10 sb.Font=Enum.Font.GothamBold sb.BorderSizePixel=0 sb.ZIndex=31 C(sb,5)
    sb.MouseButton1Click:Connect(function() estados["Fly"]=false stopFly() setStat("Fly OFF",VM) end)
    flyC=RS.Heartbeat:Connect(function()
        local h2=getH() if not h2 then stopFly() return end
        local bv2=h2:FindFirstChild("WHBv") local bg2=h2:FindFirstChild("WHBg") if not bv2 or not bg2 then return end
        local cam=workspace.CurrentCamera local dir=Vector3.new()
        for k,v in pairs(held) do if type(v)=="userdata" then dir=dir+v elseif v=="front" then dir=dir+cam.CFrame.LookVector elseif v=="left" then dir=dir-cam.CFrame.RightVector elseif v=="right" then dir=dir+cam.CFrame.RightVector end end
        if UIS:IsKeyDown(Enum.KeyCode.W) then dir=dir+cam.CFrame.LookVector end if UIS:IsKeyDown(Enum.KeyCode.S) then dir=dir-cam.CFrame.LookVector end if UIS:IsKeyDown(Enum.KeyCode.A) then dir=dir-cam.CFrame.RightVector end if UIS:IsKeyDown(Enum.KeyCode.D) then dir=dir+cam.CFrame.RightVector end if UIS:IsKeyDown(Enum.KeyCode.Space) then dir=dir+Vector3.new(0,1,0) end if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then dir=dir-Vector3.new(0,1,0) end
        bv2.Velocity=dir.Magnitude>0 and dir.Unit*60 or Vector3.new() bg2.CFrame=cam.CFrame
    end)
    setStat("Fly ON! Use botoes ou WASD",VD)
end

-- COLETA GENERICA
local function fCollect(on)
    sl("collect") if not on then return end
    local kws={"brainrot","collect","pickup","drop","item","rare","common","uncommon","epic","legendary","mythical","cosmic","secret","celestial","divine","infinity","paradox"}
    loops["collect"]=RS.Stepped:Connect(function()
        local h=getH() if not h then return end
        for _,o in pairs(workspace:GetDescendants()) do local n=o.Name:lower() for _,k in pairs(kws) do if n:find(k) then local pos=gPos(o) if pos and (h.Position-pos).Magnitude<100 then h.CFrame=CFrame.new(pos+Vector3.new(0,3,0)) act(o) end break end end end
    end)
end

-- GHOST COLLECT (coleta raridade e volta pra base)
local function ghostCol(kw,nome,sNome)
    spawn(function()
        while estados[sNome] do
            local h=getH()
            if h then
                local found={}
                for _,o in pairs(workspace:GetDescendants()) do if o.Name:lower():find(kw) then local p=gPos(o) if p then found[#found+1]={o=o,p=p} end end end
                if #found>0 then
                    setStat("Coletando: "..nome,AM)
                    for _,item in pairs(found) do if not estados[sNome] then break end local h2=getH() if not h2 then break end h2.CFrame=CFrame.new(item.p+Vector3.new(0,3,0)) task.wait(0.15) act(item.o) end
                    local base=find({"base","plot","homebase","spawn"}) local bp=gPos(base) local h3=getH() if h3 and bp then h3.CFrame=CFrame.new(bp+Vector3.new(0,4,0)) end
                    setStat(nome.." coletado! Voltei pra base.",VD)
                else setStat("Procurando "..nome.."...",TXS) end
            end
            task.wait(3)
        end
    end)
end

local function fLucky(on)
    sl("lucky") if not on then return end
    local kws={"lucky","block","luckblock","radioactive","ufo","money","gamer","candy","volcanic","frostfire","jackpot","arcade","rainbow","admin","divine","spring","golden","nest"}
    spawn(function()
        while estados["Auto Lucky Blocks"] do
            local h=getH() if h then for _,o in pairs(workspace:GetDescendants()) do local n=o.Name:lower() for _,k in pairs(kws) do if n:find(k) then local pos=gPos(o) if pos then h.CFrame=CFrame.new(pos+Vector3.new(0,3,0)) task.wait(0.2) act(o) end break end end end end
            task.wait(6)
        end
    end)
end

local function fBase()
    local h=getH() if not h then return end local cnt=0
    for _,o in pairs(workspace:GetDescendants()) do local n=o.Name:lower() if n:find("base") or n:find("slot") or n:find("place") or n:find("pad") then local pos=gPos(o) if pos then h.CFrame=CFrame.new(pos+Vector3.new(0,3,0)) task.wait(0.18) act(o) cnt=cnt+1 task.wait(0.08) end end end
    setStat("Base: "..cnt.." slots",VD)
end

local function fMoney(on)
    sl("money") if not on then return end
    spawn(function()
        while estados["Auto Collect Money"] do
            local h=getH() if h then for _,o in pairs(workspace:GetDescendants()) do local n=o.Name:lower() if n:find("money") or n:find("cash") or n:find("coin") or n:find("earn") then local pos=gPos(o) if pos then local h2=getH() if h2 then h2.CFrame=CFrame.new(pos.X,h2.Position.Y,pos.Z) task.wait(0.1) act(o) end end end end end
            task.wait(2)
        end
    end)
end

local function fRoleta() local o=find({"spin","roleta","wheel","roulette"}) if o then tp(gPos(o)) task.wait(0.35) act(o) setStat("Roleta girada!",VD) end end
local function fRebirth() local o=find({"rebirth"}) if o then tp(gPos(o)) task.wait(0.4) act(o) setStat("Rebirth feito!",VD) end end
local function fTorre()
    setStat("Indo para a Torre...",AM)
    local o=find({"tower","torre","tsunamitower","trial"}) if not o then o=find({"celestial","angel"}) end if o then tp(gPos(o)) end
    task.wait(1.5) local cnt=0
    for _,o2 in pairs(workspace:GetDescendants()) do local n=o2.Name:lower() if n:find("deliver") or n:find("deposit") or n:find("submit") then local h=getH() local pos=gPos(o2) if h and pos then h.CFrame=CFrame.new(pos+Vector3.new(0,3,0)) task.wait(0.3) act(o2) cnt=cnt+1 end end end
    setStat("Torre: "..cnt.." interacoes",VD)
end
local function fFullBright(on)
    if on then LT.Brightness=10 LT.ClockTime=14 LT.FogEnd=1e6 LT.GlobalShadows=false LT.Ambient=Color3.fromRGB(255,255,255)
    else LT.Brightness=2 LT.ClockTime=14 LT.FogEnd=100000 LT.GlobalShadows=true LT.Ambient=Color3.fromRGB(100,100,100) end
    setStat(on and "FullBright ON" or "FullBright OFF",on and VD or VM)
end
local function fNoclip(on) sl("noclip") if not on then return end loops["noclip"]=RS.Stepped:Connect(function() local c=getC() if not c then return end for _,p in pairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end end) end
local function fInfJump(on) sl("ijump") if not on then return end loops["ijump"]=UIS.JumpRequest:Connect(function() local hm=getHm() if hm then hm:ChangeState(Enum.HumanoidStateType.Jumping) end end) end
local function fSteal(on) sl("steal") if not on then return end loops["steal"]=RS.Stepped:Connect(function() local h=getH() if not h then return end for _,o in pairs(workspace:GetDescendants()) do local n=o.Name:lower() if n:find("mythical") or n:find("celestial") or n:find("infinity") or n:find("paradox") or n:find("divine") or n:find("secret") then local pos=gPos(o) if pos and (h.Position-pos).Magnitude<80 then h.CFrame=CFrame.new(pos+Vector3.new(0,3,0)) act(o) end end end end) end
local function fESP(on) if not on then for _,p in pairs(game:GetService("Players"):GetPlayers()) do if p~=LP and p.Character then local bb=p.Character:FindFirstChild("WHESP") if bb then bb:Destroy() end end end return end local function ae(p) if not p.Character then p.CharacterAdded:Wait() end local c=p.Character if not c then return end local bb=Instance.new("BillboardGui",c) bb.Name="WHESP" bb.Size=UDim2.new(0,110,0,28) bb.StudsOffset=Vector3.new(0,3,0) bb.AlwaysOnTop=true local l=Instance.new("TextLabel",bb) l.Size=UDim2.new(1,0,1,0) l.BackgroundColor3=Color3.new(0,0,0) l.BackgroundTransparency=0.5 l.Text=p.Name l.TextColor3=VM l.TextSize=12 l.Font=Enum.Font.GothamBold C(l,4) end for _,p in pairs(game:GetService("Players"):GetPlayers()) do if p~=LP then spawn(function() ae(p) end) end end end

-- ANTI DETECCAO v6 (principal novo sistema)
-- O jogo usa BAC (Behavior Analysis Check) para detectar scripts
-- Estrategia: simular comportamento humano + evitar acoes suspeitas
local antiDetC=nil
local function fAntiDet(on)
    if antiDetC then antiDetC:Disconnect() antiDetC=nil end
    if not on then setStat("Anti-Det OFF",VM) return end
    local tick0=tick()
    local moves=0
    antiDetC=RS.Heartbeat:Connect(function()
        -- A cada 30 segundos simula movimento humano aleatorio
        if tick()-tick0 > 30 then
            tick0=tick()
            local hm=getHm()
            if hm then
                -- Movimento sutil que parece humano
                local h=getH()
                if h then
                    local r=math.random(1,4)
                    if r==1 then hm.Jump=true task.delay(0.1,function() hm.Jump=false end)
                    elseif r==2 then hm.WalkSpeed=hm.WalkSpeed+0.1 task.delay(0.2,function() hm.WalkSpeed=math.max(16,hm.WalkSpeed-0.1) end)
                    end
                end
            end
        end
    end)
    setStat("Anti-Deteccao ON - BAC bypass",VD)
end

