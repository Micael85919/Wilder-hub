secTit("Fishing LTM (Novo)")
addTog("Auto Fishing LTM","Coleta brainrots no modo Fishing.",function(on) sl("fishing") if not on then return end loops["fishing"]=RS.Stepped:Connect(function() local h=getH() if not h then return end for _,o in pairs(workspace:GetDescendants()) do local n=o.Name:lower() if n:find("fish") or n:find("rod") or n:find("pesca") or n:find("catch") then local pos=gPos(o) if pos and (h.Position-pos).Magnitude<100 then h.CFrame=CFrame.new(pos+Vector3.new(0,3,0)) act(o) end end end end) end)
addBtn("Ir Fishing LTM","Vai para o portal do Fishing LTM.",function() local o=find({"fishing","ltm","fish.*portal","ltm.*machine"}) if o then tp(gPos(o)) else local o2=find({"machine","portal","event"}) if o2 then tp(gPos(o2)) end end end)
secTit("Tower Paradox (Paradox)")
addTog("Auto Tower Paradox","Entrega brainrots na torre p/ Paradox.",function(on) sl("towpar") if not on then return end spawn(function() while estados["Auto Tower Paradox"] do local o=find({"tower","tsunamitower","trial"}) if o then local pos=gPos(o) if pos then local h=getH() if h then h.CFrame=CFrame.new(pos+Vector3.new(0,4,0)) task.wait(1) for _,o2 in pairs(workspace:GetDescendants()) do local n=o2.Name:lower() if n:find("deliver") or n:find("submit") or n:find("deposit") then act(o2) end end end end end task.wait(8) end end) end)
secTit("Eventos do Jogo")
addTog("Auto Popcorn","Clica no minigame automaticamente.",function(on) sl("popcorn") if not on then return end loops["popcorn"]=RS.Stepped:Connect(function() for _,o in pairs(workspace:GetDescendants()) do local n=o.Name:lower() if n:find("popcorn") or n:find("pipoca") then act(o) end end end) end)
addTog("Auto Candy","Clica no minigame automaticamente.",function(on) sl("candy") if not on then return end loops["candy"]=RS.Stepped:Connect(function() for _,o in pairs(workspace:GetDescendants()) do local n=o.Name:lower() if n:find("candy") or n:find("doce") then act(o) end end end) end)
addBtn("Ir Torre e Entregar","Vai ate a torre e entrega brainrots.",fTorre)
addBtn("Detectar Evento","Vai ate o evento ativo.",function() local kws={"event","phantom","radioactive","doom","easter","pascoa","fire","ice","candy","arcade","fishing","money","wacky","frenzy"} local o=find(kws) if o then setStat("Evento: "..o.Name,AM) tp(gPos(o)) else setStat("Sem evento detectado",VM) end end)
addBtn("Obby Radioativo","Vai ao obby radioativo (coins).",function() local o=find({"radioactive","obby","toxic"}) if o then tp(gPos(o)) end end)

