local pages={} local curPage="" local sideBtns={}
local function showPage(nome)
    for _,ch in pairs(CS:GetChildren()) do if ch:IsA("GuiObject") and ch~=CL then ch:Destroy() end end
    for n,b in pairs(sideBtns) do if n==nome then b.BackgroundColor3=SEL b.BackgroundTransparency=0 else b.BackgroundTransparency=1 end end
    curPage=nome
    if pages[nome] then for _,fn in pairs(pages[nome]) do fn() end end
end
local function addSBtn(nome,ico)
    local b=Instance.new("TextButton",SS) b.Size=UDim2.new(1,0,0,46) b.BackgroundColor3=SB b.BackgroundTransparency=1 b.Text="" b.BorderSizePixel=0 b.ZIndex=13
    local ind=Instance.new("Frame",b) ind.Size=UDim2.new(0,3,0.6,0) ind.Position=UDim2.new(0,0,0.2,0) ind.BackgroundColor3=DT ind.BorderSizePixel=0 ind.Visible=false ind.ZIndex=14 C(ind,2)
    local iL=Instance.new("TextLabel",b) iL.Size=UDim2.new(1,0,0,20) iL.Position=UDim2.new(0,0,0,5) iL.BackgroundTransparency=1 iL.Text=ico iL.TextColor3=TX iL.TextSize=13 iL.Font=Enum.Font.GothamBold iL.ZIndex=14
    local nL=Instance.new("TextLabel",b) nL.Size=UDim2.new(1,-4,0,16) nL.Position=UDim2.new(0,2,0,25) nL.BackgroundTransparency=1 nL.Text=nome nL.TextColor3=TXS nL.TextSize=9 nL.Font=Enum.Font.Gotham nL.TextWrapped=true nL.ZIndex=14
    local ld=Instance.new("Frame",b) ld.Size=UDim2.new(0.8,0,0,1) ld.Position=UDim2.new(0.1,0,1,-1) ld.BackgroundColor3=DIV ld.BorderSizePixel=0 ld.ZIndex=14
    sideBtns[nome]=b
    b.MouseButton1Click:Connect(function()
        showPage(nome) ind.Visible=true iL.TextColor3=BR nL.TextColor3=TX
        for n2,b2 in pairs(sideBtns) do if n2~=nome then local i2=b2:FindFirstChildOfClass("Frame") if i2 then i2.Visible=false end end end
    end)
end
