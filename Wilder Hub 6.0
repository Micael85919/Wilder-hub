        local dL=Instance.new("TextLabel",f) dL.Size=UDim2.new(1,-60,0,22) dL.Position=UDim2.new(0,10,0,28) dL.BackgroundTransparency=1 dL.Text=desc or "" dL.TextColor3=TXS dL.TextSize=10 dL.Font=Enum.Font.Gotham dL.TextXAlignment=Enum.TextXAlignment.Left dL.TextWrapped=true dL.ZIndex=14
        local pb=Instance.new("TextButton",f) pb.Size=UDim2.new(0,42,0,22) pb.Position=UDim2.new(1,-50,0.5,-11) pb.BackgroundColor3=Color3.fromRGB(50,50,70) pb.Text="" pb.BorderSizePixel=0 pb.ZIndex=14 C(pb,11)
        local pl=Instance.new("Frame",pb) pl.Size=UDim2.new(0,18,0,18) pl.Position=UDim2.new(0,2,0.5,-9) pl.BackgroundColor3=TXS pl.BorderSizePixel=0 pl.ZIndex=15 C(pl,9)
        pb.MouseButton1Click:Connect(function()
            estados[nome]=not estados[nome]
            if estados[nome] then pb.BackgroundColor3=DT TS:Create(pl,TweenInfo.new(0.15),{Position=UDim2.new(1,-20,0.5,-9),BackgroundColor3=BR}):Play() setStat(nome.." ON",VD)
            else pb.BackgroundColor3=Color3.fromRGB(50,50,70) TS:Create(pl,TweenInfo.new(0.15),{Position=UDim2.new(0,2,0.5,-9),BackgroundColor3=TXS}):Play() setStat(nome.." OFF",VM) end
            if cb then pcall(cb,estados[nome]) end
        end)
    end
end
