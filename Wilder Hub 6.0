        local l=Instance.new("TextLabel",f) l.Size=UDim2.new(1,-10,1,0) l.Position=UDim2.new(0,8,0,0) l.BackgroundTransparency=1 l.Text=txt l.TextColor3=BR l.TextSize=11 l.Font=Enum.Font.GothamBold l.TextXAlignment=Enum.TextXAlignment.Left l.ZIndex=14
    end
end
local function addTog(nome,desc,cb)
    estados[nome]=false
    pages[curPage][#pages[curPage]+1]=function()
        local f=Instance.new("Frame",CS) f.Size=UDim2.new(1,0,0,54) f.BackgroundTransparency=1 f.BorderSizePixel=0 f.ZIndex=13
        local lb=Instance.new("Frame",f) lb.Size=UDim2.new(1,-16,0,1) lb.Position=UDim2.new(0,8,1,-1) lb.BackgroundColor3=DIV lb.BorderSizePixel=0 lb.ZIndex=14
