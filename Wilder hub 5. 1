-- =====================
-- KEY VERIFICACAO
-- =====================
local function verKey()
    local k=kBox.Text:gsub("%s","")
    if k==KEY then
        kMsg.Text="Key correta! Abrindo..." kMsg.TextColor3=VD
        task.wait(0.8)
        TS:Create(KBG,TweenInfo.new(0.5),{BackgroundTransparency=1}):Play()
        for _,v in pairs(KBG:GetDescendants()) do if v:IsA("GuiObject") then TS:Create(v,TweenInfo.new(0.4),{BackgroundTransparency=1}):Play() if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then TS:Create(v,TweenInfo.new(0.4),{TextTransparency=1}):Play() end end end
        task.wait(0.5) KBG.Visible=false FAB.Visible=true setStat("Toque em W para abrir o menu!",VD)
    else
        kMsg.Text="Key incorreta! Pegue no Discord." kMsg.TextColor3=VM
        local orig=KP.Position
        for _=1,4 do KP.Position=UDim2.new(orig.X.Scale,orig.X.Offset+7,orig.Y.Scale,orig.Y.Offset) task.wait(0.05) KP.Position=UDim2.new(orig.X.Scale,orig.X.Offset-7,orig.Y.Scale,orig.Y.Offset) task.wait(0.05) end
        KP.Position=orig
    end
end

kConf.MouseButton1Click:Connect(verKey)
kBox.FocusLost:Connect(function(e) if e then verKey() end end)

