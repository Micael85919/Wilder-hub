local godC=nil
local function fGod(on)
    if godC then godC:Disconnect() godC=nil end
    if not on then local c=getC() if c then for _,p in pairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=true p.Transparency=0 end end end local hm=getHm() if hm then hm.PlatformStand=false end setStat("God Mode OFF",VM) return end
    -- God Mode: vida infinita + remove dano do tsunami + anti-void
    godC=RS.Heartbeat:Connect(function()
        local h=getH() local hm=getHm() if not h or not hm then return end
        -- Vida sempre cheia
        if hm.Health < hm.MaxHealth then hm.Health = hm.MaxHealth end
        -- Remove colisao do tsunami/wave com personagem
        for _,o in pairs(workspace:GetDescendants()) do
            local n=o.Name:lower()
            if n:find("tsunami") or n:find("wave") or n:find("flood") or n:find("kill") or n:find("damage") or n:find("hurt") then
                if o:IsA("BasePart") then pcall(function() o.CanCollide=false end) end
            end
        end
        -- Anti-void: se cair abaixo do mapa volta
        if h.Position.Y < -15 then h.CFrame=CFrame.new(h.Position.X,5,h.Position.Z) end
    end)
    -- Anti deteccao: humanoid nao fica com PlatformStand (suspeito)
    setStat("God Mode ON - Invulneravel!",VD)
end

